# community lists, etc.) live under state_scrapers/<state>/leads/ and ARE
# committed.
!state_scrapers/**/leads/*.json

# docs (PDFs)
hoa_docs/
legal_corpus/

# Personal / business documents
*.pdf
*.docx

# Screenshots and design artifacts
*.png
!api/static/favicon-48x48.png
!api/static/og-card.png

# Internal working docs / one-off scripts
claude-memory/
TODO.md
state_hoa_laws.md
docs/hoa-law-corpus-execution-log.md
docs/ux-fix-list.md
scripts/gcp_billing_cap/

# Generated scraping / benchmark output
benchmark/results/
state_scrapers/**/results/
state_scrapers/**/cache/

# Orchestrator runtime artifacts (regenerated every run)
state_scrapers/_orchestrator/*.pid
state_scrapers/_orchestrator/*.log
state_scrapers/_orchestrator/*.run_id
state_scrapers/_orchestrator/nohup.out
state_scrapers/_orchestrator/*_nohup.out
state_scrapers/_orchestrator/*_DONE.flag
state_scrapers/_orchestrator/quality_audit_*/

# Per-state run markers used by the orchestrator
state_scrapers/**/notes/.active_run*

# Claude Code / Playwright working dirs
.claude/
.playwright-mcp/

# macOS
.DS_Store
