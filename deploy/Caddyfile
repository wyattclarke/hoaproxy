# /etc/caddy/Caddyfile — TLS-terminating reverse proxy in front of uvicorn.
#
# TLS strategy: Cloudflare Origin Certificate (15-year validity), generated
# in the Cloudflare dashboard → SSL/TLS → Origin Server → Create Certificate.
# Cloudflare's edge runs Full (strict) mode and validates this cert.
#
# Path on disk:
#   /etc/hoaproxy/cf-origin.crt
#   /etc/hoaproxy/cf-origin.key

{
    # No automatic HTTPS — we use Cloudflare Origin Certs, not Let's Encrypt.
    auto_https off
    admin off
}

# Match both apex and www (Cloudflare proxies both).
hoaproxy.org, www.hoaproxy.org {
    tls /etc/hoaproxy/cf-origin.crt /etc/hoaproxy/cf-origin.key

    encode zstd gzip

    # Restrict to Cloudflare's edge IPs. Anyone else hitting :443 directly
    # gets 403. Cloudflare auto-updates the IP list; pull periodically with
    # the refresh script in deploy/refresh-cloudflare-ips.sh.
    @cloudflare {
        remote_ip 173.245.48.0/20 103.21.244.0/22 103.22.200.0/22 103.31.4.0/22 \
                  141.101.64.0/18 108.162.192.0/18 190.93.240.0/20 188.114.96.0/20 \
                  197.234.240.0/22 198.41.128.0/17 162.158.0.0/15 104.16.0.0/13 \
                  104.24.0.0/14 172.64.0.0/13 131.0.72.0/22 \
                  2400:cb00::/32 2606:4700::/32 2803:f800::/32 2405:b500::/32 \
                  2405:8100::/32 2a06:98c0::/29 2c0f:f248::/32
    }

    handle @cloudflare {
        # Preserve the real client IP for request logging / abuse handling.
        request_header X-Forwarded-For {http.request.header.CF-Connecting-IP}
        request_header X-Forwarded-Proto https

        reverse_proxy 127.0.0.1:8000 {
            # Big bodies for /upload (PDF uploads can be 50+ MB).
            flush_interval -1
        }
    }

    handle {
        respond "Forbidden — Cloudflare-only origin" 403
    }

    log {
        output file /var/log/caddy/hoaproxy-access.log {
            roll_size 100mb
            roll_keep 5
            roll_keep_for 90d
        }
        format json
    }
}

# Catch-all on port 80 — redirect to HTTPS apex.
:80 {
    redir https://hoaproxy.org{uri} permanent
}
