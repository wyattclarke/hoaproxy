# OpenAI embeddings (required for search/QA retrieval)
OPENAI_API_KEY=sk-your-openai-key-here

# Q&A chat completions (OpenAI-compatible). Defaults to Groq + Llama-3.3-70B.
# Override QA_API_BASE_URL/QA_MODEL to point at any compatible endpoint.
QA_API_BASE_URL="https://api.groq.com/openai/v1"
QA_API_KEY=gsk_your-groq-key-here
QA_MODEL="llama-3.3-70b-versatile"

# Qdrant (local defaults; adjust if using hosted)
QDRANT_URL="http://localhost:6333"
QDRANT_API_KEY=""

# Document storage & DB
HOA_DOCS_ROOT="hoa_docs"
HOA_DB_PATH="data/hoa_index.db"

# Chunking / OCR toggles
HOA_CHUNK_CHAR_LIMIT="1800"
HOA_CHUNK_OVERLAP="200"
HOA_ENABLE_OCR="1"
HOA_OCR_DPI="300"

# Google Cloud Document AI (optional — set HOA_ENABLE_DOCAI=1 to enable)
GOOGLE_APPLICATION_CREDENTIALS="path/to/your-gcp-service-account.json"
HOA_ENABLE_DOCAI="0"
HOA_DOCAI_PROJECT_ID=""
HOA_DOCAI_LOCATION="us"
HOA_DOCAI_PROCESSOR_ID=""
HOA_DOCAI_ENDPOINT=""

# JWT auth (generate with: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET=change-me-to-a-random-hex-string

# Google OAuth (optional — enables "Sign in with Google")
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Google Analytics (optional — leave blank to disable)
GA_MEASUREMENT_ID=G-BV7JXG4JDE

# Email (optional — defaults to stub which just logs)
EMAIL_PROVIDER=stub
EMAIL_FROM=noreply@example.com
# RESEND_API_KEY=re_your-resend-key-here

# Weekly cost report (optional — sends every Sunday 6pm UTC)
COST_REPORT_EMAIL=
# GA4 property ID for traffic stats in weekly report (numeric, not G-xxx)
GA4_PROPERTY_ID=

# ---------------------------------------------------------------------------
# Deployment & infrastructure (contributors do NOT need these — only needed
# by the project maintainer for production deploys and DNS management)
# ---------------------------------------------------------------------------

# DB backup (GCS bucket name — uses GOOGLE_APPLICATION_CREDENTIALS)
BACKUP_GCS_BUCKET=hoaproxy-backups

# Render hosting
RENDER_API_KEY=
RENDER_SERVICE_ID=

# Cloudflare Registrar
CLOUDFLARE_API_KEY=

# Resend email service (production)
RESEND_API_KEY=

# Smoke test accounts (used by CI / e2e tests against production)
SMOKE_TEST_EMAIL=
SMOKE_TEST_PASSWORD=
SMOKE_TEST_EMAIL_2=
SMOKE_TEST_PASSWORD_2=
SMOKE_TEST_EMAIL_3=
SMOKE_TEST_PASSWORD_3=

# Email delivery testing (testmail.app)
TESTMAIL_API_KEY=
TESTMAIL_NAMESPACE=
